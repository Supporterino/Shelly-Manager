{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/guidelines.md",
    "docs/security.md",
    ".opencode/instructions/ctx-host-first.md"
  ],
  "mcp": {
    "ctx": {
      "command": [
        "/opt/homebrew/bin/ctx",
        "--repo-root",
        "/Users/supporterino/WebstormProjects/Shelly-Manager",
        "mcp",
        "stdio"
      ],
      "enabled": true,
      "type": "local"
    },
    "mantine": {
      "command": [
        "npx",
        "-y",
        "@mantine/mcp-server"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "provider": {
    "lmstudio": {
      "models": {
        "google/gemma-4-26b-a4b": {
          "name": "Gemma4 26B A4B"
        },
        "openai/gpt-oss-20b": {
          "name": "GPT OSS 20B"
        }
      }
    }
  }
}
